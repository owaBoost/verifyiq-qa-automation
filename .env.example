# Required
VERIFYIQ_API_KEY=
GH_TOKEN=

# Environment URLs
DEV_URL=https://parser-dev.boostkh.com
GATEWAY_DEV_URL=https://parser-dev.boostkh.com

# Preview URL pattern for ai-parser-studio PRs.
# Note: different repos may deploy preview URLs with different patterns.
# If you test PRs in other repos, this single pattern won't fit all of them —
# known limitation; auto-discovery via GitHub deployments API is a future improvement.
PREVIEW_URL_PATTERN=https://ai-parser-pr-{NUMBER}-z6thvhgnxa-uc.a.run.app

# Gateway endpoints (/ai-gateway/batch-upload, /api/v1/applications/):
# Confirm with team — sample expected from QA owner
PREVIEW_GATEWAY_URL_PATTERN=

# Legacy — only needed if PREVIEW_URL_PATTERN is unset (backward compat)
VERIFYIQ_SERVICE_URL=

# PR target — can also be set via --pr owner/repo#number CLI flag
PR_REPO=boost-capital/ai-parser-studio
PR_NUMBER=

# IAP authentication for dev/staging environments
USE_IAP=true
IAP_CLIENT_ID=900560280527-mg3aghjm6sp2tc0k99ldarp9fioadfo8.apps.googleusercontent.com

# ClickUp integration (optional — used for --clickup test-case generation context)
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=9014784260
CLICKUP_QA_SPACE_ID=90144486664
CLICKUP_API_TEST_CASES_FOLDER_ID=90147709410
CLICKUP_FOLDER_ID=90147709410

# Required only for batch tests (/ai-gateway/ endpoints)
GOOGLE_SA_KEY_FILE=C:\Users\Admin\Downloads\qa-api-tester-key.json

# Webhook server URL for batch-upload callbacks.
# Get the URL for your environment from the team.
# Format: https://verifyiq-webhook-server-<project-number>.us-central1.run.app
WEBHOOK_SERVER_URL=
WEBHOOK_TOKEN_ID=
