  "fixture_creation_rules": {
    "step_1": "Check fixture-registry.json first — use existing baseline if it satisfies the scenario",
    "step_2": "Check gs://qa-automation-dev/** and gs://verifyiq-internal-testing/QA/** for additional fixtures",
    "step_3": "If no suitable fixture exists — create synthetic file using Python (Pillow, qrcode, reportlab)",
    "step_4": "Upload new fixtures to gs://verifyiq-internal-testing/QA/[DocType]/[descriptive-name].[ext]",
    "step_5": "Add new fixture to fixture-registry.json and commit",
    "naming_convention": {
      "complete": "[bank]-[doctype]-complete.[ext]",
      "partial": "[bank]-[doctype]-partial.[ext]",
      "tampered": "[doctype]-tampered-[what].[ext]",
      "damaged": "[doctype]-damaged-[what].[ext]",
      "synthetic": "synthetic-[doctype]-[scenario].[ext]"
    }
  }
